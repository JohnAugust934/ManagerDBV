# =============================================================================
# TEMPLATE DE CONFIGURAÇÃO PARA PRODUÇÃO — ManagerDBV
# Copie este arquivo para .env e preencha todos os valores marcados com TODO
# NUNCA commite o .env com valores reais no repositório
# =============================================================================

APP_NAME="Desbravadores"          # TODO: nome do clube
APP_ENV=production                 # OBRIGATÓRIO: nunca alterar em produção
APP_KEY=                           # TODO: gerar com: php artisan key:generate
APP_DEBUG=false                    # OBRIGATÓRIO: nunca true em produção
APP_URL=https://seudominio.com.br  # TODO: URL real com HTTPS

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12                   # mínimo 12 em produção

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                  # OBRIGATÓRIO: nunca debug em produção

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# Para SQLite (padrão): deixar DB_CONNECTION=sqlite, demais comentados
# Para PostgreSQL/MySQL: configurar abaixo
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=managerdbv
# DB_USERNAME=managerdbv_user
# DB_PASSWORD=                     # TODO se usar PostgreSQL/MySQL

SESSION_DRIVER=database
SESSION_LIFETIME=60                # recomendado: 60 minutos em produção
SESSION_ENCRYPT=true               # OBRIGATÓRIO: sempre true em produção
SESSION_PATH=/
SESSION_DOMAIN=                    # TODO: domínio (ex: .seudominio.com.br)

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_MONITOR_ENABLED=true
QUEUE_MONITOR_QUEUE=default
QUEUE_MONITOR_MAX_SIZE=50
QUEUE_MONITOR_PAUSE_WINDOWS=02:45-04:45

CACHE_STORE=database

# -----------------------------------------------------------------------------
# E-MAIL (OBRIGATÓRIO — convites e notificações de backup)
# Opções: smtp, mailgun, postmark, resend
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp                   # TODO: configurar provedor real
MAIL_SCHEME=tls
MAIL_HOST=smtp.seudominio.com.br   # TODO
MAIL_PORT=587
MAIL_USERNAME=                     # TODO
MAIL_PASSWORD=                     # TODO
MAIL_FROM_ADDRESS="sistema@seudominio.com.br"  # TODO
MAIL_FROM_NAME="${APP_NAME}"
BACKUP_NOTIFICATIONS_MAIL_TO=admin@seudominio.com.br  # TODO

# -----------------------------------------------------------------------------
# BACKUP (spatie/laravel-backup)
# BACKUP_DESTINATION_DISKS: "local" ou "local,r2" se usar Cloudflare R2
# -----------------------------------------------------------------------------
BACKUP_DESTINATION_DISKS=local,r2
BACKUP_MONITOR_DISKS=local,r2
BACKUP_VERIFY=true
BACKUP_ARCHIVE_ENCRYPTION=default
BACKUP_ARCHIVE_PASSWORD=          # TODO: senha para criptografia do arquivo ZIP
BACKUP_MONITOR_MAX_AGE_DAYS=1
BACKUP_MONITOR_MAX_STORAGE_MB=5000

# Notificações opcionais (deixar vazios se não usar)
BACKUP_SLACK_WEBHOOK_URL=
BACKUP_DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# TELEGRAM (notificações de erros e operacional)
# Criar bot via @BotFather e obter CHAT_ID via @userinfobot
# -----------------------------------------------------------------------------
TELEGRAM_NOTIFICATIONS_ENABLED=true   # TODO: configurar bot
TELEGRAM_BOT_TOKEN=                    # TODO: token do bot
TELEGRAM_CHAT_ID=                      # TODO: ID do chat/grupo
TELEGRAM_PARSE_MODE=HTML
TELEGRAM_TIMEOUT=10
TELEGRAM_ADMIN_NOTIFICATIONS=true
TELEGRAM_ERROR_NOTIFICATIONS=true
TELEGRAM_ERROR_DEDUP_SECONDS=300
TELEGRAM_SUPPRESS_TRANSIENT_DB_ERRORS=true
TELEGRAM_TRANSIENT_DB_SUPPRESS_WINDOWS=02:45-04:45

# -----------------------------------------------------------------------------
# CLOUDFLARE R2 (backup remoto — opcional mas recomendado)
# Configurar em Cloudflare Dashboard > R2 > Manage API Tokens
# IMPORTANTE: o disco "r2" (config/filesystems.php) lê estas variáveis R2_*.
# Não confundir com AWS_* (disco "s3" genérico, não usado pelo backup).
# Se R2_BUCKET ficar vazio, o disco r2 é descartado automaticamente e o
# backup grava apenas em "local" (ver config/backup.php).
# -----------------------------------------------------------------------------
R2_ACCESS_KEY_ID=                  # TODO: R2 Access Key ID
R2_SECRET_ACCESS_KEY=              # TODO: R2 Secret Access Key
R2_BUCKET=                         # TODO: nome do bucket R2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com  # TODO

VITE_APP_NAME="${APP_NAME}"
